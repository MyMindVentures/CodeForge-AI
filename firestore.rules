rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Collection: projects/{projectId}/documents
    // Collection: projects/{projectId}/runs
    // Collection: runs/{runId}/artifacts
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProject(data) {
      return hasRequiredFields(['id', 'name']) &&
             hasOnlyAllowedFields(['id', 'name', 'repo_url', 'branch', 'auth_reference', 'sync_settings', 'framework', 'deployment_target', 'status', 'policy', 'verdict', 'created_at']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && isValidProject(request.resource.data);
      allow delete: if isAuthenticated();
      
      match /documents/{documentId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
      
      match /runs/{runId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }
    
    match /runs/{runId}/artifacts/{artifactId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
